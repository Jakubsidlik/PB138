generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum UserRole {
  REGISTERED
  ADMIN
}

enum EventRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum CollaborationRole {
  VIEWER
  CONTRIBUTOR
}

enum AnnotationTargetType {
  LESSON
  LESSON_NOTE
  FILE_COMMENT
}

model User {
  id            BigInt    @id @default(autoincrement())
  fullName      String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(REGISTERED)
  school        String?
  faculty       String?
  studyMajor    String?
  studyYear     String?
  studyType     String?
  birthDate     DateTime? @db.Date
  bio           String?    @db.Text
  avatarDataUrl String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subjects      Subject[]
  tasks         Task[]
  fileRecords   FileRecord[]
  fileComments  FileComment[]
  lessonNotes   LessonNote[]
  studyPlans    StudyPlan[]
  collaborations StudyPlanCollaborator[]
  textAnnotations TextAnnotation[]
  events        Event[]

  @@index([deletedAt])
}

model StudyPlan {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  name        String
  description String?
  faculty     String?
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  isActive    Boolean   @default(true)
  isShared    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects      Subject[]
  tasks         Task[]
  lessons       Lesson[]
  collaborators StudyPlanCollaborator[]

  @@index([userId])
  @@index([isActive])
  @@index([isShared])
}

model StudyPlanCollaborator {
  id          BigInt            @id @default(autoincrement())
  studyPlanId BigInt
  userId      BigInt
  role        CollaborationRole @default(VIEWER)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  studyPlan   StudyPlan         @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studyPlanId, userId])
  @@index([userId])
}

model Subject {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  studyPlanId BigInt?
  name        String
  teacher     String
  code        String
  isShared    Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyPlan    StudyPlan?   @relation(fields: [studyPlanId], references: [id], onDelete: SetNull)
  tasks        Task[]
  events       Event[]
  files        FileRecord[]
  lessons      Lesson[]

  @@index([userId])
  @@index([studyPlanId])
  @@index([isShared])
  @@index([deletedAt])
  @@unique([userId, code])
}

model Task {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt
  subjectId BigInt?
  studyPlanId BigInt?
  title     String
  done      Boolean   @default(false)
  favorite  Boolean   @default(false)
  tag       String?
  deadline  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  studyPlan    StudyPlan?   @relation(fields: [studyPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subjectId])
  @@index([studyPlanId])
  @@index([deadline])
  @@index([deletedAt])
}

model FileRecord {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt
  subjectId  BigInt?
  lessonId   BigInt?
  name       String
  size       Int
  addedLabel String
  isShared   Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  lesson     Lesson?     @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  comments   FileComment[]

  @@index([userId])
  @@index([subjectId])
  @@index([lessonId])
  @@index([isShared])
  @@index([deletedAt])
}

model FileComment {
  id         BigInt       @id @default(autoincrement())
  fileId      BigInt
  userId      BigInt
  comment     String       @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  file        FileRecord   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
}

model Lesson {
  id          BigInt      @id @default(autoincrement())
  subjectId   BigInt?
  studyPlanId BigInt?
  title       String
  content     String?     @db.Text
  isShared    Boolean     @default(false)
  orderIndex  Int
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subject     Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  studyPlan   StudyPlan?   @relation(fields: [studyPlanId], references: [id], onDelete: SetNull)
  notes       LessonNote[]
  files       FileRecord[]

  @@index([subjectId])
  @@index([studyPlanId])
  @@index([isShared])
  @@index([deletedAt])
}

model LessonNote {
  id            BigInt    @id @default(autoincrement())
  lessonId       BigInt
  userId         BigInt
  note           String   @db.Text
  isPinned       Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lesson        Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model Event {
  id         BigInt      @id @default(autoincrement())
  userId     BigInt
  subjectId  BigInt?
  title      String
  date       DateTime
  time       String?
  location   String?
  isShared   Boolean          @default(false)
  recurrence EventRecurrence @default(NONE)
  recurrenceGroupId String?
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subjectId])
  @@index([isShared])
  @@index([date])
  @@index([deletedAt])
  @@index([recurrenceGroupId])
}

model TextAnnotation {
  id           BigInt               @id @default(autoincrement())
  targetType   AnnotationTargetType
  targetId     BigInt
  userId       BigInt
  startOffset  Int
  endOffset    Int
  selectedText String               @db.Text
  comment      String               @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([userId])
}
