generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FileCategory {
  folder
  pdf
  image
  document
  other
}

enum AccentType {
  primary
  amber
  emerald
}

enum EntityType {
  SUBJECT
  FILE
  PROFILE
  TASK
  EVENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  REPLACE_SYNC
}

enum UserRole {
  student
  registered
  public
}

enum SubjectAccess {
  private
  registered
  public
}

enum LessonFormat {
  lecture
  seminar
  lab
}

enum EventKind {
  deadline
  exam
  consultation
  meeting
}

model User {
  id            BigInt    @id @default(autoincrement())
  name          String
  email         String    @unique
  role          UserRole  @default(student)
  institution   String
  bio           String
  avatarDataUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subjects      Subject[] @relation("SubjectOwner")
}

model Subject {
  id        BigInt    @id @default(autoincrement())
  name      String
  teacher   String
  code      String    @unique
  ownerId   BigInt?
  access    SubjectAccess @default(registered)
  description String   @default("")
  color     String     @default("indigo")
  archived  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tasks     Task[]
  events    Event[]
  files     FileRecord[]
  audits    AuditLog[]
  owner     User?     @relation("SubjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  lessons   Lesson[]
}

model Lesson {
  id         BigInt      @id @default(autoincrement())
  subjectId  BigInt?
  title      String
  startsAt   DateTime
  endsAt     DateTime
  room       String
  format     LessonFormat @default(lecture)
  shared     Boolean      @default(false)
  notes      String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  subject    Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Task {
  id        BigInt    @id @default(autoincrement())
  title     String
  done      Boolean   @default(false)
  subjectId BigInt?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subject   Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Event {
  id         BigInt      @id @default(autoincrement())
  title      String
  date       DateTime
  time       String?
  location   String?
  icon       String?
  accent     AccentType?
  subjectId  BigInt?
  kind       EventKind?  
  shared     Boolean     @default(false)
  startsAt   DateTime?
  endsAt     DateTime?
  description String     @default("")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  subject    Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model FileRecord {
  id         BigInt       @id @default(autoincrement())
  name       String
  size       String
  addedLabel String
  category   FileCategory @default(other)
  shared     Boolean      @default(false)
  subjectId  BigInt?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  subject    Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Profile {
  id            BigInt    @id @default(autoincrement())
  fullName      String
  email         String
  school        String
  studyMajor    String
  studyYear     String
  studyType     String
  avatarDataUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AuditLog {
  id         BigInt      @id @default(autoincrement())
  entityType EntityType
  action     AuditAction
  entityId   BigInt?
  subjectId  BigInt?
  payload    Json?
  createdAt  DateTime    @default(now())

  subject    Subject?    @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([entityType, createdAt])
  @@index([subjectId, createdAt])
}

model User {
  id        BigInt    @id @default(autoincrement())
  fullName  String
  email     String    @unique
  school    String
  studyMajor String
  studyYear String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}